{
  "name": "battle-buddy",
  "version": "0.2.1",
  "description": "Pokemon-like CLI battle game with Claude Code companion buddies",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "battle-buddy": "./bin/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "game",
    "battle",
    "pokemon",
    "multiplayer",
    "claude"
  ],
  "author": "Alex Wong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wongcode/battle-buddy.git"
  },
  "homepage": "https://github.com/wongcode/battle-buddy#readme",
  "bugs": {
    "url": "https://github.com/wongcode/battle-buddy/issues"
  },
  "type": "commonjs",
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
